# IMAP credentials for OTP verification
# For Gmail: use an App Password (NOT your regular password)
# Enable 2FA → Google Account → Security → App passwords

IMAP_USER=your@gmail.com
IMAP_PASS=abcd efgh ijkl mnop
EMAIL_DOMAIN=your-catchall-domain.com

# Optional: override IMAP server (defaults to imap.gmail.com:993)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# Optional: override results file path (defaults to results.json)
# RESULTS_FILE=results.json

# Qwen Cloud Farm credentials
QWEN_GMAIL_USER=your@gmail.com
QWEN_GMAIL_APP_PASS=your app password here

# Skip aliases (comma-separated, already registered manually)
QWEN_SKIP_ALIASES=your@gmail.com

# CapSolver API key (for reCAPTCHA solving)
CAPSOLVER_API_KEY=your_capsolver_api_key
SMTPLABS_KEY=your_smtplabs_key
EMAIL_DOMAIN=your-domain.com
CATCHALL_ID=your_catchall_id
INBOX_ID=your_inbox_id
