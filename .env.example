# IMAP credentials for OTP verification
# For Gmail: use an App Password (NOT your regular password)
# Enable 2FA → Google Account → Security → App passwords

IMAP_USER=your@gmail.com
IMAP_PASS=abcd efgh ijkl mnop
EMAIL_DOMAIN=your-catchall-domain.com

# Optional: override IMAP server (defaults to imap.gmail.com:993)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# Optional: override results file path (defaults to results.json)
# RESULTS_FILE=results.json
